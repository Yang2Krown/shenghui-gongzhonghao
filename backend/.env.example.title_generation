# 标题生成Agent系统 - 环境变量配置示例

# 项目配置
PROJECT_NAME=标题生成Agent系统
VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./title_generation.db
DATABASE_ECHO=false

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI模型配置
# 主模型: Claude 3.5 Sonnet
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 备用模型: GPT-4o
OPENAI_API_KEY=your_openai_api_key_here

# 模型选择
USE_PRIMARY_MODEL=true
PRIMARY_MODEL=claude-3-5-sonnet-20241022
FALLBACK_MODEL=gpt-4o

# 模型参数
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096

# 标题生成配置
MIN_CANDIDATES=10
MAX_CANDIDATES=15
TARGET_CANDIDATES=12

# 评分配置
B_SCORE_WEIGHT=0.6
C_SCORE_WEIGHT=0.4
PASS_THRESHOLD=7.0

# 重生配置
MAX_REGENERATIONS=1

# API调用配置
MAX_API_RETRIES=3
API_TIMEOUT=60

# 套路配置
MIN_COVERAGE_METHODS=6
MAX_SAME_METHOD=3
PRIORITY_METHOD_RATIO=0.7

# 字数配置
MIN_TITLE_LENGTH=10
MAX_TITLE_LENGTH=22
OPTIMAL_MIN_LENGTH=14
OPTIMAL_MAX_LENGTH=20

# 修饰元素配置
MAX_MODIFIERS_PER_TITLE=3
