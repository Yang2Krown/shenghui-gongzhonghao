# ============================================================
# 生产环境 .env 模板
# 复制为 .env.production 后填入真实值，然后：
#   docker compose -f docker-compose.prod.yml --env-file backend/.env.production up -d
# ============================================================

# 项目配置
PROJECT_NAME=AI公众号选题平台
DEBUG=false

# 安全配置（生产必须改）
SECRET_KEY=请用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成新值
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# 数据库（docker-compose 里的 service 名当 host）
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=换成强密码
POSTGRES_DB=ai_content_hub

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ====== LLM ======
DEEPSEEK_API_KEY=你的 DeepSeek key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com

# ====== Embedding ======
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=你的 DashScope key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ====== 默认 provider ======
LLM_PROVIDER=deepseek

# ====== TopHub ======
TOPHUB_API_KEY=你的 TopHub key
TOPHUB_API_BASE=https://api.tophubdata.com

# ====== X (Twitter) cookie ——可选 ======
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ====== 前端 / nginx ======
# 服务器上跑在 80 端口（如果 80 被宝塔占了，改成 8080）
WEB_HTTP_PORT=80

# CORS（前端域名）
BACKEND_CORS_ORIGINS=["https://your-domain.com","http://your-server-ip"]
ALLOWED_HOSTS=["your-domain.com","your-server-ip","localhost"]

# 上传
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760
