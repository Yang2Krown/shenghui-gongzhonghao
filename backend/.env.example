# 后端环境变量示例文件
# 复制此文件为 .env 并填入实际值

# 项目配置
PROJECT_NAME=AI公众号内容运营平台
DEBUG=true

# 安全配置
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# 数据库配置（生产 = Postgres + pgvector）
# 本地 dev：连 Docker 里的 pgvector 容器；生产：连服务器上的 pgvector
# 注意：必须用 pgvector 镜像（pgvector/pgvector:pg16 等），普通 postgres 没装 vector 扩展
POSTGRES_SERVER=localhost
POSTGRES_PORT=54328              # 服务器上一般是 5432
POSTGRES_USER=root               # 改成你服务器上的用户
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_content_hub

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ====== LLM 配置 ======
# DeepSeek (Phase 2 默认: 信息类型 + 要素提取)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Anthropic Claude (Phase 3 默认: Agent A/B 选题挖掘)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_BASE=https://api.anthropic.com

# OpenAI / 通义千问 (备用)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
TONGYI_API_KEY=
TONGYI_API_BASE=https://dashscope.aliyuncs.com/api/v1

# ====== Embedding 配置 ======
# 默认阿里云百炼 text-embedding-v3，OpenAI-compatible
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ====== TopHub 榜眼数据 API ======
# 接入 36kr / 虎嗅 / 知乎 / 微信公众号 / 量子位 等热榜
TOPHUB_API_KEY=your-tophub-key
TOPHUB_API_BASE=https://api.tophubdata.com

# ====== 默认 provider ======
LLM_PROVIDER=deepseek            # deepseek / anthropic
DEFAULT_AI_MODEL=deepseek-chat
DEFAULT_AI_PROVIDER=deepseek

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
